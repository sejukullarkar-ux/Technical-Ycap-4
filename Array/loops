
#include <stdio.h>

int main(){
      int a[]={1,2,3,4,5};
      
      for(int i=0;i<5;i++){
          printf("%d\t",a[i]);
      }
      
      printf("\n");
      int i=0;
      while(i<5){
        printf("%d\t",a[i]);
        i++; 
      }
      
      printf("\n");
      int j=0;
       do{
        printf("%d\t",a[j]);
        j++; 
      }while(j<5);
      return 0;
}
