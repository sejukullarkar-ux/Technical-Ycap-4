typedef struct {
    int price;
    int span;
} Node;

typedef struct {
    Node a[100000];
    int top;
} StockSpanner;


StockSpanner* stockSpannerCreate() {
    StockSpanner* obj=(StockSpanner*)malloc(sizeof(StockSpanner));
    obj->top=-1;
    return obj;
}

int stockSpannerNext(StockSpanner* obj, int price) {
    int span=1;
    while(obj->top>=0 && obj->a[obj->top].price<=price){
        span+=obj->a[obj->top].span;
        obj->top--;
    }
    obj->top++;
    obj->a[obj->top].price=price;
    obj->a[obj->top].span=span;
    return span;
}
void stockSpannerFree(StockSpanner* obj) {
    
}

